<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.image.ImageView?>

<Pane fx:id="fightPane"
      prefWidth="800"
      prefHeight="600"
      focusTraversable="true"
      onKeyPressed="#moverPlayer"
      onMouseClicked="#atacar"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.undertale_3.controller.FightController"
      styleClass="fight-root">

    <Rectangle width="800"
               height="600"
               styleClass="fight-background"/>

    <Label fx:id="vidaInimigoLabel"
           layoutX="300"
           layoutY="40"
           text="Vida do inimigo"
           styleClass="fight-title"/>

    <ImageView fx:id="player"
               layoutX="380"
               layoutY="500"
               fitWidth="80"
               fitHeight="80"
               preserveRatio="true"/>

    <ImageView fx:id="inimigo"
               layoutX="350"
               layoutY="250"
               fitWidth="170"
               fitHeight="170"
               preserveRatio="true"/>

</Pane>