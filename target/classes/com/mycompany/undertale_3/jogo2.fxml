<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.undertale_3.controller.Jogo2Controller"
            styleClass="game-root">

    <top>
        <HBox spacing="25"
              alignment="CENTER_LEFT"
              styleClass="hud"
              prefHeight="60">

            <Label fx:id="nomeLabel" text="Jogador" />
            <Label fx:id="hpLabel" text="HP: 100/100" />
            <Label fx:id="moedasLabel" text="Moedas: 0" />
            <Label fx:id="pontosLabel" text="Pontos: 0" />

            <Button text="Inventário" onAction="#abrirInventario" />
            <Button text="Loja" onAction="#abrirLoja" />
            <Button text="Upgrades" onAction="#abrirUpgrades" />
            <Button fx:id="bossBtn" text="Boss" onAction="#abrirBoss" />
            <Button text="Desistir" onAction="#desistir" />
        </HBox>
    </top>

    <center>
        <Pane fx:id="mapaPane"
              prefWidth="900"
              prefHeight="540"
              styleClass="mapa"
              focusTraversable="true"
              onKeyPressed="#teclaPressionada">

            <Rectangle x="60"
                       y="60"
                       width="760"
                       height="430"
                       arcWidth="20"
                       arcHeight="20"
                       styleClass="arena" />

            <ImageView fx:id="player"
                       layoutX="120"
                       layoutY="150"
                       fitWidth="55"
                       fitHeight="75"
                       preserveRatio="true" />

            <ImageView fx:id="inimigo1"
                       layoutX="350"
                       layoutY="170"
                       fitWidth="70"
                       fitHeight="70"
                       preserveRatio="true" />

            <ImageView fx:id="inimigo2"
                       layoutX="570"
                       layoutY="320"
                       fitWidth="70"
                       fitHeight="70"
                       preserveRatio="true" />

            <ImageView fx:id="inimigo3"
                       layoutX="720"
                       layoutY="180"
                       fitWidth="70"
                       fitHeight="70"
                       preserveRatio="true" />

            <ImageView fx:id="inimigo4"
                       layoutX="220"
                       layoutY="270"
                       fitWidth="70"
                       fitHeight="70"
                       preserveRatio="true" />

            <ImageView fx:id="inimigo5"
                       layoutX="720"
                       layoutY="260"
                       fitWidth="70"
                       fitHeight="70"
                       preserveRatio="true" />

            <ImageView fx:id="bau1"
                       layoutX="270"
                       layoutY="380"
                       fitWidth="65"
                       fitHeight="55"
                       preserveRatio="true" />

            <ImageView fx:id="bau2"
                       layoutX="670"
                       layoutY="420"
                       fitWidth="65"
                       fitHeight="55"
                       preserveRatio="true" />

            <ImageView fx:id="bau3"
                       layoutX="460"
                       layoutY="320"
                       fitWidth="65"
                       fitHeight="55"
                       preserveRatio="true" />

            <ImageView fx:id="bossPortal"
                       layoutX="760"
                       layoutY="390"
                       fitWidth="100"
                       fitHeight="100"
                       preserveRatio="true" />

            <VBox layoutX="20"
                  layoutY="505"
                  spacing="8">

                <Label fx:id="msgLabel"
                       text="Derrote 3 inimigos para desbloquear o Boss."
                       styleClass="msg" />
            </VBox>

        </Pane>
    </center>

</BorderPane>