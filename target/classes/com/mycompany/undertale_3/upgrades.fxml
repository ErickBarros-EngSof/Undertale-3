<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18" styleClass="painel" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.mycompany.undertale_3.controller.UpgradesController">
    <Label styleClass="titulo-menor" text="UPGRADES PERMANENTES" />
    <Label fx:id="pontosLabel" />
    <Button onAction="#comprarHp" text="Comprar +20 HP - 120 pontos" />
    <Button onAction="#comprarAtk" text="Comprar +5 Ataque - 100 pontos" />
    <Button onAction="#comprarDef" text="Comprar +3 Defesa - 110 pontos" />
    <Button onAction="#voltar" text="Voltar" />
</VBox>
