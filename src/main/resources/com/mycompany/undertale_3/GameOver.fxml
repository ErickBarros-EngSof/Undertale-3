<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>

<Pane prefWidth="800" prefHeight="600"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.undertale_3.controller.GameOverController">

    <Pane prefWidth="800" prefHeight="600" style="-fx-background-color: black;"/>

    <Label layoutX="260" layoutY="190"
           text="GAME OVER"
           style="-fx-text-fill: red; -fx-font-size: 52; -fx-font-weight: bold;"/>

    <Button
    text="Tela Inicial"
    onAction="#voltarTelaInicial"
    layoutX="320"
    layoutY="320"
    prefWidth="160"
    prefHeight="45"/>
</Pane>
