<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.image.ImageView?>

<Pane prefWidth="800" prefHeight="600"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.undertale_3.controller.CombatMenuController">

    <Pane prefWidth="800" prefHeight="600" style="-fx-background-color: black;"/>

    <Label fx:id="inimigoLabel" layoutX="350" layoutY="100" text="Inimigo" style="-fx-text-fill: white; -fx-font-size: 24;"/>
    
    <ImageView fx:id="inimigo1" layoutX="200" layoutY="100" fitWidth="400" fitHeight="400" preserveRatio="true"/>

    <Button layoutX="230" layoutY="450" text="Lutar" onAction="#lutar"/>
    <Button layoutX="350" layoutY="450" text="Conversar" onAction="#conversar"/>
    <Button layoutX="500" layoutY="450" text="Fugir" onAction="#fugir"/>

    <Label fx:id="mensagemLabel" layoutX="180" layoutY="520" text="" style="-fx-text-fill: white; -fx-font-size: 16;"/>

</Pane>